---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { episodes, SPOTIFY_URL, YOUTUBE_URL, APPLE_URL } from "../data/episodes.js";

function formatDate(d) {
  return new Date(d + "T00:00:00").toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

const platforms = [
  { key: "podbean", label: "Podbean" },
  { key: "apple", label: "Apple Podcasts" },
  { key: "spotify", label: "Spotify" },
  { key: "youtube", label: "YouTube" },
];
---
<BaseLayout title="The Dudela Podcast" description="John & Mike, unfiltered. Every episode of The Dudela Podcast — listen on Podbean, Apple Podcasts, Spotify, or YouTube.">
  <Nav />

  <section class="page-hero section-dark">
    <div class="container">
      <p class="eyebrow">The Dudela Podcast</p>
      <h1>John &amp; Mike, unfiltered.</h1>
      <p class="hero-sub">{episodes.length} episodes and counting. New ones drop regularly.</p>
      <div class="follow-row">
        <span class="follow-label">Follow the show:</span>
        <a href={APPLE_URL} target="_blank" rel="noopener" class="follow-link">Apple Podcasts</a>
        <a href={SPOTIFY_URL} target="_blank" rel="noopener" class="follow-link">Spotify</a>
        <a href={YOUTUBE_URL} target="_blank" rel="noopener" class="follow-link">YouTube</a>
      </div>
    </div>
  </section>

  <section class="episode-list section-light">
    <div class="container">
      <div class="episodes">
        {episodes.map((ep) => (
          <div class="episode-row">
            <img src={ep.img} alt={ep.title} class="episode-thumb" loading="lazy" />
            <div class="episode-info">
              <h3>{ep.title}</h3>
              <p class="episode-date">{formatDate(ep.date)}</p>
              <div class="episode-links">
                <a href={ep.link} target="_blank" rel="noopener" class="listen-link">Podbean</a>
                <a href={ep.apple} target="_blank" rel="noopener" class="listen-link">Apple</a>
                <a href={SPOTIFY_URL} target="_blank" rel="noopener" class="listen-link">Spotify</a>
                <a href={YOUTUBE_URL} target="_blank" rel="noopener" class="listen-link">YouTube</a>
              </div>
            </div>
          </div>
        ))}
      </div>
      <p class="episode-note">
        Apple and Podbean links go straight to that episode. Spotify and YouTube link to the show —
        we're still working on exact episode links for those two.
      </p>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    padding: 9rem 0 3.5rem;
  }
  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    margin: 0.5rem 0 0.75rem;
  }
  .hero-sub {
    color: var(--text-on-dark-muted);
    margin: 0 0 1.25rem;
  }
  .follow-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }
  .follow-label {
    font-family: var(--font-label);
    font-size: 0.85rem;
    color: var(--text-on-dark-muted);
  }
  .follow-link {
    font-family: var(--font-label);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--cream-100);
    text-decoration: none;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--forest-600);
    border-radius: 999px;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .follow-link:hover {
    border-color: var(--amber-500);
    background: var(--forest-700);
  }
  .episode-list {
    padding: var(--space-6) 0;
  }
  .episodes {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .episode-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1.5rem;
    align-items: center;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border-light);
    color: var(--text-on-light);
  }
  .episode-thumb {
    width: 140px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }
  .episode-info h3 {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 1.05rem;
    margin: 0 0 0.3rem;
  }
  .episode-date {
    font-size: 0.85rem;
    color: var(--text-on-light-muted);
    margin: 0 0 0.6rem;
  }
  .episode-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .listen-link {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: var(--forest-800);
    border: 1px solid var(--border-light);
    border-radius: 999px;
    padding: 0.3rem 0.75rem;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .listen-link:hover {
    border-color: var(--forest-800);
  }
  .episode-note {
    margin-top: 1.5rem;
    font-size: 0.8rem;
    color: var(--text-on-light-muted);
  }
</style>
