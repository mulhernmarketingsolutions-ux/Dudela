---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---
<BaseLayout title="Leave a Voicemail — Dudela" description="Tell us what's on your mind. We're listening.">
  <Nav />

  <section class="hero section-dark">
    <div class="container hero-inner">
      <p class="eyebrow">Ask Another Dad</p>
      <h1>Leave us a voicemail.</h1>
      <p class="hero-sub">
        Whatever you're carrying right now — say it out loud. John and Mike listen to every
        one of these.
      </p>
      <p class="hero-hint">
        Look for the <strong>voicemail tab</strong> on the edge of your screen — click it to
        record and send. Same tool we've always used, works right in your browser.
      </p>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .hero {
    padding: 9rem 0 6rem;
    text-align: center;
  }
  .hero-inner {
    max-width: 520px;
    margin: 0 auto;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3rem);
    margin: 0.5rem 0 1rem;
  }
  .hero-sub {
    color: var(--text-on-dark-muted);
    margin-bottom: 1.5rem;
  }
  .hero-hint {
    color: var(--text-on-dark-muted);
    font-size: 0.95rem;
  }
  .hero-hint strong {
    color: var(--amber-500);
  }
</style>
