---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import GuideCover from "../components/GuideCover.astro";

const resources = [
  { name: "Free Dad Prep Guide", type: "Free", for: "For dads who haven't started yet", desc: "The universal starting point. Five sections: emotional, financial, partnership, advocacy, identity.", href: "/guide", featured: true },
  { name: "Dudela Prep Kit", type: "$37", for: "For dads who want the full playbook", desc: "The flagship guide. Six pillars, nine printable tools, real founder stories.", href: "/kit", featured: true },
  { name: "Hospital Bag Checklist", type: "Coming Soon", for: "For dads a few weeks out from delivery", desc: "Everything to pack, nothing you don't need.", comingSoon: true },
  { name: "Birth Plan Template", type: "Coming Soon", for: "For dads walking into the delivery room", desc: "Know your job in the room before you're in it.", comingSoon: true },
  { name: "Baby Shower Checklist", type: "Coming Soon", for: "For dads hosting or helping plan", desc: "Show up for her, not just the gifts.", comingSoon: true },
  { name: "Sleep Survival Guide", type: "Coming Soon", for: "For dads in the newborn fog", desc: "Be steady even when you're exhausted.", comingSoon: true },
  { name: "Return-to-Work Guide", type: "Coming Soon", for: "For dads heading back to the office", desc: "Show up for your job without checking out at home.", comingSoon: true },
  { name: "Dad Challenges", type: "Coming Soon", for: "For dads who want small wins this week", desc: "Small, specific things to do this week.", comingSoon: true },
];
---
<BaseLayout title="Resources — Dudela" description="Free guides and checklists, organized by what you need next.">
  <Nav />

  <section class="page-hero section-dark">
    <div class="container">
      <p class="eyebrow">Resources</p>
      <h1>Everything free, organized by what you need next.</h1>
      <p class="hero-sub">Not sure where to start? The Dad Roadmap sorts these by stage automatically.</p>
      <a href="/prepare" class="btn btn-primary">Go to the Dad Roadmap</a>
    </div>
  </section>

  <section class="resource-list section-light">
    <div class="container resource-grid">
      {resources.map((r) => {
        const Tag = r.comingSoon ? "div" : "a";
        return (
          <Tag class={`resource-card ${r.comingSoon ? "coming-soon" : ""}`} href={r.comingSoon ? undefined : r.href}>
            <GuideCover title={r.name} kicker={r.type} ratio="16/11" compact class="resource-cover-el" />
            <div class="resource-body">
              <h3>{r.name}</h3>
              <p class="resource-for">{r.for}</p>
              <p>{r.desc}</p>
            </div>
          </Tag>
        );
      })}
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    padding: 9rem 0 3.5rem;
  }
  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    max-width: 18ch;
    margin: 0.5rem 0 1rem;
  }
  .hero-sub {
    color: var(--text-on-dark-muted);
    margin-bottom: 1.75rem;
    max-width: 46ch;
  }
  .resource-list {
    padding: var(--space-6) 0;
  }
  .resource-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .resource-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-md);
    background: var(--bg-light-raised);
    border: 1px solid var(--border-light);
    text-decoration: none;
    color: var(--text-on-light);
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .resource-card:hover {
    border-color: var(--amber-500);
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(18, 24, 15, 0.1);
  }
  .resource-card.coming-soon {
    cursor: default;
    opacity: 0.7;
  }
  .resource-card.coming-soon:hover {
    border-color: var(--border-light);
    transform: none;
    box-shadow: none;
  }
  .resource-cover-el {
    border-radius: 0;
  }
  .resource-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem 1.75rem 1.75rem;
  }
  .resource-card h3 {
    font-family: var(--font-label);
    font-size: 1.1rem;
    margin: 0;
  }
  .resource-for {
    font-family: var(--font-label);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--amber-500) !important;
    margin: 0 !important;
  }
  .resource-card p {
    font-size: 0.9rem;
    color: var(--text-on-light-muted);
    margin: 0;
  }
</style>
