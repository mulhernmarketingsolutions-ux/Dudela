---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const resources = [
  { name: "Free Dad Prep Guide", type: "Free", for: "For dads who haven't started yet", desc: "The universal starting point. Five sections: emotional, financial, partnership, advocacy, identity.", href: "/guide", featured: true },
  { name: "Dudela Prep Kit", type: "$37", for: "For dads who want the full playbook", desc: "The flagship guide. Six pillars, nine printable tools, real founder stories.", href: "/kit", featured: true },
  { name: "Hospital Bag Checklist", type: "Free", for: "For dads a few weeks out from delivery", desc: "Everything to pack, nothing you don't need.", href: "#", img: "/images/IMG_0215_VSCO.JPG" },
  { name: "Birth Plan Template", type: "Free", for: "For dads walking into the delivery room", desc: "Know your job in the room before you're in it.", href: "#", img: "/images/IMG_1582_VSCO.JPG" },
  { name: "Baby Shower Checklist", type: "Free", for: "For dads hosting or helping plan", desc: "Show up for her, not just the gifts.", href: "#", img: "/images/IMG_7213.JPG" },
  { name: "Sleep Survival Guide", type: "Free", for: "For dads in the newborn fog", desc: "Be steady even when you're exhausted.", href: "#", img: "/images/IMG_9055_VSCO.jpeg" },
  { name: "Return-to-Work Guide", type: "Free", for: "For dads heading back to the office", desc: "Show up for your job without checking out at home.", href: "#", img: "/images/IMG_6495.JPG" },
  { name: "Dad Challenges", type: "Free", for: "For dads who want small wins this week", desc: "Small, specific things to do this week.", href: "#", img: "/images/IMG_2506.JPG" },
];
---
<BaseLayout title="Resources — Dudela" description="Free guides and checklists, organized by what you need next.">
  <Nav />

  <section class="page-hero section-dark">
    <div class="container">
      <p class="eyebrow">Resources</p>
      <h1>Everything free, organized by what you need next.</h1>
      <p class="hero-sub">Not sure where to start? The Dad Roadmap sorts these by stage automatically.</p>
      <a href="/prepare" class="btn btn-primary">Go to the Dad Roadmap</a>
    </div>
  </section>

  <section class="resource-list section-light">
    <div class="container resource-grid">
      {resources.map((r) => (
        <a class={`resource-card ${r.featured ? "featured" : ""}`} href={r.href}>
          {r.img && (
            <div class="resource-cover">
              <img src={r.img} alt="" loading="lazy" />
              <span class="resource-type">{r.type}</span>
            </div>
          )}
          {!r.img && <span class="resource-type resource-type-standalone">{r.type}</span>}
          <div class="resource-body">
            <h3>{r.name}</h3>
            <p class="resource-for">{r.for}</p>
            <p>{r.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    padding: 9rem 0 3.5rem;
  }
  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    max-width: 18ch;
    margin: 0.5rem 0 1rem;
  }
  .hero-sub {
    color: var(--text-on-dark-muted);
    margin-bottom: 1.75rem;
    max-width: 46ch;
  }
  .resource-list {
    padding: var(--space-6) 0;
  }
  .resource-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .resource-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-md);
    background: var(--bg-light-raised);
    border: 1px solid var(--border-light);
    text-decoration: none;
    color: var(--text-on-light);
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .resource-card:hover {
    border-color: var(--amber-500);
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(18, 24, 15, 0.1);
  }
  .resource-cover {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .resource-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .resource-cover::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(18, 24, 15, 0) 45%, rgba(18, 24, 15, 0.65) 100%);
  }
  .resource-type {
    font-family: var(--font-label);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--cream-100);
    font-weight: 700;
    position: absolute;
    left: 1rem;
    bottom: 0.85rem;
    z-index: 1;
    background: rgba(18, 24, 15, 0.55);
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
  }
  .resource-type-standalone {
    position: static;
    color: var(--rust-600);
    background: none;
    padding: 1.75rem 1.75rem 0;
  }
  .resource-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem 1.75rem 1.75rem;
  }
  .resource-card.featured .resource-body {
    padding-top: 1.75rem;
  }
  .resource-card h3 {
    font-family: var(--font-label);
    font-size: 1.1rem;
    margin: 0;
  }
  .resource-for {
    font-family: var(--font-label);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--amber-500) !important;
    margin: 0 !important;
  }
  .resource-card p {
    font-size: 0.9rem;
    color: var(--text-on-light-muted);
    margin: 0;
  }
</style>
