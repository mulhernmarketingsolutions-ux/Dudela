---
import BaseLayout from "../layouts/BaseLayout.astro";

// Mirrors the real link-in-bio page (used in Instagram/TikTok bios), plus
// the two affiliate/product links that live there: the Gumroad Prep Kit
// checkout and the Taking Cara Babies sleep affiliate link.
const links = [
  { label: "Get the Free Dad Prep Guide", href: "/guide", tag: "Free", primary: true },
  { label: "The Dudela Prep Kit", href: "https://dudelaco.gumroad.com/l/dudela-prep-kit", tag: "$37", external: true },
  { label: "Taking Cara Babies", sub: "The sleep resource we recommend to every dad", href: "https://www.takingcarababies.com?sca_ref=11694397.hvn2tySyLaykC", tag: null, external: true },
  { label: "The Dudela Podcast", href: "https://open.spotify.com/show/19bw724AZVIygPb52pCOnQ", tag: null, external: true },
  { label: "Join the Spit-Up Society", href: "/join/spit-up-society", tag: "$5/mo" },
  { label: "Leave Us a Voicemail", href: "/voicemail", tag: null },
];
---
<BaseLayout title="Start Here — Dudela" description="Everything Dudela, in one place.">
  <main class="start-here">
    <div class="start-here-inner">
      <a href="/" class="wordmark"><img src="/logo/dudela-wordmark-cream.png" alt="Dudela" /></a>
      <p class="tagline">Turning Dudes Into Dads</p>

      <div class="link-list">
        {links.map((l) => (
          <a
            class={`link-btn ${l.primary ? "primary" : ""}`}
            href={l.href}
            target={l.external ? "_blank" : undefined}
            rel={l.external ? "noopener" : undefined}
          >
            <span class="link-btn-text">
              <span class="link-btn-label">{l.label}</span>
              {l.sub && <span class="link-btn-sub">{l.sub}</span>}
            </span>
            {l.tag && <span class="tag">{l.tag}</span>}
          </a>
        ))}
      </div>

      <div class="socials">
        <a href="https://instagram.com/the_dudela_official" target="_blank" rel="noopener">Instagram</a>
        <a href="https://www.tiktok.com/@the_dudela_official" target="_blank" rel="noopener">TikTok</a>
        <a href="https://www.youtube.com/@TheDudela-Official/videos" target="_blank" rel="noopener">YouTube</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .start-here {
    min-height: 100svh;
    background: var(--forest-900);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
  }
  .start-here-inner {
    width: 100%;
    max-width: 420px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .wordmark img {
    height: 56px;
    width: auto;
    display: block;
  }
  .tagline {
    font-family: var(--font-display);
    color: var(--text-on-dark-muted);
    font-size: 1.1rem;
    margin: 0.5rem 0 2.5rem;
  }
  .link-list {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    width: 100%;
  }
  .link-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.4rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--forest-600);
    background: var(--forest-700);
    color: var(--cream-100);
    text-decoration: none;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 1rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .link-btn:hover {
    border-color: var(--amber-500);
    transform: translateY(-2px);
  }
  .link-btn.primary {
    background: var(--amber-500);
    border-color: var(--amber-500);
    color: var(--forest-900);
  }
  .link-btn-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    text-align: left;
  }
  .link-btn-sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.78rem;
    opacity: 0.7;
    text-transform: none;
    letter-spacing: normal;
  }
  .tag {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--amber-500);
    font-weight: 700;
    flex-shrink: 0;
  }
  .link-btn.primary .tag {
    color: var(--forest-900);
  }
  .socials {
    display: flex;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .socials a {
    color: var(--text-on-dark-muted);
    text-decoration: none;
    font-family: var(--font-label);
    font-size: 0.9rem;
  }
</style>
