---
// Real testimonials, pulled from emails and public reviews (Jul 2026).
const quotes = [
  { quote: "It's helping me prepare to become a dad and support my wife as best as possible.", name: "Nathan", role: "Dad to Be" },
  { quote: "I love your podcast. I'm just trying to figure out how to be a better dad.", name: "Jake", role: "New Dad" },
  { quote: "I wish something like Dudela had existed before I became a dad.", name: "Ryan George", role: "Dad & Creator" },
  { quote: "John and Michael create a space where dads can be honest about what they're carrying.", name: "Corey Davis", role: "Husband, Father & Entrepreneur" },
];
---
<section class="testimonials section-dark">
  <div class="container">
    <p class="eyebrow">Dads who've been where you are</p>
    <div class="quote-grid">
      {quotes.map((q) => (
        <blockquote>
          <p>&ldquo;{q.quote}&rdquo;</p>
          <cite>{q.name} <span>&middot; {q.role}</span></cite>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: var(--space-6) 0;
  }
  .quote-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
  blockquote {
    margin: 0;
    padding: 1.75rem;
    border-radius: var(--radius-md);
    background: var(--forest-700);
    border: 1px solid var(--forest-600);
  }
  blockquote p {
    font-family: var(--font-display);
    font-size: 1.2rem;
    margin: 0 0 1rem;
  }
  cite {
    font-family: var(--font-label);
    font-style: normal;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-on-dark-muted);
  }
  cite span {
    text-transform: none;
    letter-spacing: normal;
    opacity: 0.75;
  }
</style>
