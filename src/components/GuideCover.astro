---
// A designed "cover mockup" for a lead magnet (guide/checklist/template/kit) —
// stands in for a photo where a photo doesn't make sense, and makes it
// immediately clear "this is a document" via the folded-corner + label treatment.
export interface Props {
  title: string;
  kicker?: string; // e.g. "Free Guide", "$37 · Instant Download"
  ratio?: string; // e.g. "4/5", "3/4"
  compact?: boolean;
  class?: string;
}
const { title, kicker = "Free Guide", ratio = "4/5", compact = false, class: klass = "" } = Astro.props;
---
<div class={`guide-cover ${compact ? "compact" : ""} ${klass}`} style={`aspect-ratio: ${ratio};`}>
  <div class="guide-cover-fold"></div>
  <span class="guide-cover-kicker">{kicker}</span>
  <h3 class="guide-cover-title">{title}</h3>
  <div class="guide-cover-foot">
    <img src="/logo/dudela-wordmark-cream.png" alt="" class="guide-cover-mark" />
  </div>
</div>

<style>
  .guide-cover {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background:
      repeating-linear-gradient(
        135deg,
        rgba(245, 239, 227, 0.035) 0px,
        rgba(245, 239, 227, 0.035) 2px,
        transparent 2px,
        transparent 16px
      ),
      linear-gradient(160deg, #2a3322 0%, #1c2319 55%, #12180f 100%);
    box-shadow: inset 0 0 0 1px rgba(245, 239, 227, 0.08);
  }
  .guide-cover-fold {
    position: absolute;
    top: 0;
    right: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 34px 34px 0;
    border-color: transparent var(--cream-100) transparent transparent;
    opacity: 0.9;
  }
  .guide-cover-fold::after {
    content: "";
    position: absolute;
    top: 2px;
    right: -32px;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 14px 14px 0;
    border-color: transparent rgba(18, 24, 15, 0.25) transparent transparent;
  }
  .guide-cover-kicker {
    font-family: var(--font-label);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--amber-500);
    margin-bottom: 0.75rem;
  }
  .guide-cover-title {
    font-family: var(--font-display);
    color: var(--cream-100);
    font-size: 1.6rem;
    line-height: 1.18;
    margin: 0 0 2rem;
  }
  .guide-cover-foot {
    display: flex;
    align-items: center;
  }
  .guide-cover-mark {
    height: 18px;
    width: auto;
    opacity: 0.85;
  }
  .guide-cover.compact {
    padding: 1.1rem;
  }
  .guide-cover.compact .guide-cover-title {
    font-size: 1.15rem;
    margin-bottom: 1.25rem;
  }
  .guide-cover.compact .guide-cover-fold {
    border-width: 0 24px 24px 0;
  }
  .guide-cover.compact .guide-cover-mark {
    height: 14px;
  }
</style>
