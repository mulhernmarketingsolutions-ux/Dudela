---
import { slugify } from "../data/episodes.js";

const stages = [
  {
    id: "ttc",
    label: "Trying to Conceive",
    mission: "Get your head right before the two lines show up.",
    free: [{ title: "Why We Started Dudela (And What's Next for New Dads)", type: "Episode" }],
    paid: null,
  },
  {
    id: "8wk",
    label: "8 Weeks",
    mission: "The news is real. Now what?",
    free: [
      { title: "Free Dad Prep Guide", type: "Guide" },
      { title: "The Emotional Side of Fatherhood Nobody Talks About", type: "Episode" },
    ],
    paid: null,
  },
  {
    id: "12wk",
    label: "12 Weeks",
    mission: "Start telling people. Start telling yourself.",
    free: [{ title: "Family Matters Part 3: Rhythms, Mission, & Building your family with Josh Mackey", type: "Episode" }],
    paid: null,
  },
  {
    id: "shower",
    label: "Baby Shower",
    mission: "Show up for her, not just the gifts.",
    free: [
      { title: "Baby Shower Checklist", type: "Checklist" },
      { title: "Easy Financial Wins For Dads, Even on a Budget", type: "Episode" },
    ],
    paid: null,
  },
  {
    id: "third-tri",
    label: "Third Trimester",
    mission: "Pack the bag. Freeze the meals. Ask her how she's really feeling.",
    free: [
      { title: "Hospital Bag Checklist", type: "Checklist" },
      { title: "What Should I Focus On Right Now? Prepping for Fatherhood Before Baby Arrives", type: "Episode" },
    ],
    paid: [{ title: "Dudela Prep Kit", price: "$37" }],
  },
  {
    id: "hospital",
    label: "Hospital",
    mission: "Know exactly what your job is in that room.",
    free: [
      { title: "Birth Plan Template", type: "Template" },
      { title: "What Moms Actually Need From Dads", type: "Episode" },
    ],
    paid: [{ title: "Steady Dad: Before Birth Workshop", price: "$100" }],
  },
  {
    id: "first-night",
    label: "First Night Home",
    mission: "You made it home. Now survive the first 24 hours.",
    free: [{ title: "Becoming the Dad You Never Had", type: "Episode" }],
    paid: [{ title: "Join the Spit-Up Society", price: "$5/mo" }],
  },
  {
    id: "sleep-regression",
    label: "Sleep Regression",
    mission: "Be steady even when you're exhausted.",
    free: [
      { title: "Sleep Survival Guide", type: "Guide" },
      { title: "How to Balance Work and a Newborn Without Losing Your Mind", type: "Episode" },
    ],
    paid: [{ title: "Sleep Coaching Cohort", price: "Coming Soon" }],
  },
  {
    id: "3mo",
    label: "3 Months",
    mission: "Find your rhythm as a family of three (or four).",
    free: [{ title: "Finding Your Rhythm as a New Dad", type: "Episode" }],
    paid: null,
  },
  {
    id: "return-work",
    label: "Returning to Work",
    mission: "Show up for your job without checking out at home.",
    free: [
      { title: "Return-to-Work Guide", type: "Guide" },
      { title: "Traveling Dad: Work Trips, Dad Guilt, and Growth", type: "Episode" },
    ],
    paid: null,
  },
  {
    id: "6mo",
    label: "6 Months",
    mission: "You're not new at this anymore. Keep going.",
    free: [{ title: "When to Prioritize Yourself as a Dad", type: "Episode" }],
    paid: [{ title: "1:1 Coaching", price: "$1,000+/mo" }],
  },
  {
    id: "first-birthday",
    label: "First Birthday",
    mission: "Look back at who you were. Look forward at who you're becoming.",
    free: [{ title: "What I Wish I Knew in Year One as a New Dad", type: "Episode" }],
    paid: null,
  },
];

function freeHref(f) {
  if (f.type === "Guide") return "/guide";
  if (f.type === "Episode") return `/podcast#${slugify(f.title)}`;
  return "/resources";
}
function paidHref(title) {
  if (title.includes("Prep Kit")) return "/kit";
  if (title.includes("Spit-Up Society")) return "/join/spit-up-society";
  return "/join";
}
function iconKind(type) {
  return type === "Episode" ? "mic" : "doc";
}

const ICONS = {
  mic: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
  doc: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="13" y2="17"/></svg>`,
  paid: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><line x1="8" y1="16" x2="16" y2="8"/><polyline points="9 8 16 8 16 15"/></svg>`,
};
---
<section class="roadmap section-light" id="roadmap">
  <div class="container">
    <p class="eyebrow">The signature feature</p>
    <h2>The Roadmap We Wish We Had</h2>
    <p class="roadmap-sub">
      We learned every one of these stages the hard way, one at a time. Tap through to see what
      we wish we'd had at each one.
    </p>

    <div class="track-wrap">
      <div class="track" id="roadmap-track">
        <div class="track-line"></div>
        <div class="track-fill" id="track-fill"></div>
        {stages.map((s, i) => (
          <button class="stage" data-stage={s.id} data-index={i} class:list={{ active: i === 4 }}>
            <span class="stage-dot">
              <span class="stage-index">{String(i + 1).padStart(2, "0")}</span>
            </span>
            <span class="stage-label">{s.label}</span>
          </button>
        ))}
      </div>
      <div class="scroll-hint" id="scroll-hint" aria-hidden="true">
        <span class="scroll-hint-arrow">&rarr;</span>
      </div>
    </div>

    <div class="panels">
      {stages.map((s, i) => (
        <div class="panel" data-panel={s.id} style={i === 4 ? "display:block" : "display:none"}>
          <p class="panel-mission-label">What We Wish We'd Known</p>
          <p class="panel-mission">{s.mission}</p>
          <div class="panel-resources">
            {s.free?.map((f) => (
              <a class="resource resource-free" href={freeHref(f)} target="_blank" rel="noopener">
                <span class="resource-icon" set:html={ICONS[iconKind(f.type)]} />
                <span class="resource-copy">
                  <span class="resource-tag">Free</span>
                  <span>{f.title}</span>
                </span>
              </a>
            ))}
            {s.paid?.map((p) => (
              <a class="resource resource-paid" href={paidHref(p.title)} target="_blank" rel="noopener">
                <span class="resource-icon" set:html={ICONS.paid} />
                <span class="resource-copy">
                  <span class="resource-tag">Next Step</span>
                  <span>{p.title} — {p.price}</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .roadmap {
    padding: var(--space-6) 0;
  }
  .roadmap h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin: 0.4rem 0 0.5rem;
  }
  .roadmap-sub {
    color: var(--text-on-light-muted);
    max-width: 52ch;
    margin-bottom: 2.5rem;
  }
  .track-wrap {
    position: relative;
    margin-bottom: 1.5rem;
  }
  .track {
    position: relative;
    display: flex;
    gap: 1.75rem;
    overflow-x: auto;
    padding: 0.5rem 0.25rem 1.25rem;
    scrollbar-width: thin;
  }
  .track-line {
    position: absolute;
    left: 0.25rem;
    right: 0.25rem;
    top: 28px;
    height: 2px;
    background: var(--border-light);
    z-index: 0;
  }
  .track-fill {
    position: absolute;
    left: 0.25rem;
    top: 28px;
    height: 2px;
    background: var(--amber-500);
    z-index: 0;
    width: 0;
    transition: width 0.35s var(--ease-out);
  }
  .stage {
    position: relative;
    z-index: 1;
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    min-width: 108px;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-label);
    text-align: center;
  }
  .stage-dot {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-light-raised);
    border: 2px solid var(--border-light);
    transition: all 0.25s var(--ease-out);
  }
  .stage:hover .stage-dot {
    border-color: var(--amber-500);
  }
  .stage.active .stage-dot {
    background: var(--forest-800);
    border-color: var(--forest-800);
  }
  .stage-index {
    font-size: 0.8rem;
    font-weight: 700;
    opacity: 0.5;
    transition: opacity 0.2s ease, color 0.2s ease;
  }
  .stage.active .stage-index {
    opacity: 1;
    color: var(--cream-100);
  }
  .stage-label {
    font-weight: 600;
    font-size: 0.85rem;
    max-width: 108px;
    line-height: 1.2;
    color: var(--text-on-light-muted);
    transition: color 0.2s ease;
  }
  .stage.active .stage-label {
    color: var(--text-on-light);
  }

  .scroll-hint {
    position: absolute;
    right: 0;
    top: 28px;
    transform: translate(50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--amber-500);
    color: var(--forest-900);
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.35s ease;
    z-index: 2;
  }
  .scroll-hint.hint-hidden {
    opacity: 0;
  }
  .scroll-hint-arrow {
    font-size: 1rem;
    line-height: 1;
    animation: hintNudge 1.1s ease-in-out infinite;
  }
  @keyframes hintNudge {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(4px); }
  }

  .panel {
    background: var(--forest-800);
    color: var(--cream-100);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }
  .panel-mission-label {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    color: var(--amber-500);
    margin: 0 0 0.75rem;
  }
  .panel-mission {
    font-family: var(--font-display);
    font-size: 1.5rem;
    max-width: 40ch;
    margin: 0 0 1.75rem;
  }
  .panel-resources {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .resource {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 1.1rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    border: 1px solid var(--forest-600);
    text-decoration: none;
    color: var(--cream-100);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .resource:hover {
    border-color: var(--amber-500);
    transform: translateY(-2px);
  }
  .resource-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    flex: 0 0 auto;
    border-radius: 50%;
    color: var(--cream-100);
    background: var(--forest-600);
  }
  .resource-icon :global(svg) {
    width: 16px;
    height: 16px;
  }
  .resource-copy {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: flex-start;
  }
  .resource-tag {
    font-family: var(--font-label);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    background: var(--forest-600);
    color: var(--cream-100);
  }
  .resource-paid {
    border-color: var(--amber-500);
  }
  .resource-paid .resource-icon {
    background: transparent;
    border: 1.5px solid var(--amber-500);
    color: var(--amber-500);
  }
  .resource-paid .resource-tag {
    background: var(--amber-500);
    color: var(--black);
  }
</style>

<script>
  const track = document.getElementById("roadmap-track");
  const trackFill = document.getElementById("track-fill");
  const scrollHint = document.getElementById("scroll-hint");

  function updateFill(btn: HTMLElement) {
    if (!track || !trackFill) return;
    const target = btn.offsetLeft + btn.offsetWidth / 2;
    trackFill.style.width = `${target}px`;
  }

  function selectStage(id: string, scroll = false) {
    const btn = track?.querySelector(`[data-stage="${id}"]`) as HTMLElement | null;
    if (!btn) return false;

    track?.querySelectorAll("[data-stage]").forEach((el) => el.classList.remove("active"));
    btn.classList.add("active");
    updateFill(btn);

    document.querySelectorAll("[data-panel]").forEach((el) => {
      (el as HTMLElement).style.display = el.getAttribute("data-panel") === id ? "block" : "none";
    });

    if (scroll) {
      btn.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
    }
    return true;
  }

  if (track) {
    track.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("[data-stage]") as HTMLElement | null;
      if (!btn || !btn.dataset.stage) return;
      selectStage(btn.dataset.stage, false);
    });

    const activeBtn = track.querySelector(".stage.active") as HTMLElement | null;
    if (activeBtn) updateFill(activeBtn);

    track.addEventListener(
      "scroll",
      () => {
        scrollHint?.classList.add("hint-hidden");
      },
      { once: true, passive: true }
    );

    // If the track doesn't overflow (nothing to scroll), don't show the hint at all.
    if (track.scrollWidth <= track.clientWidth + 4) {
      scrollHint?.classList.add("hint-hidden");
    }

    const params = new URLSearchParams(window.location.search);
    const stageParam = params.get("stage");
    if (stageParam) {
      selectStage(stageParam, true);
    }

    window.addEventListener("resize", () => {
      const active = track.querySelector(".stage.active") as HTMLElement | null;
      if (active) updateFill(active);
      if (track.scrollWidth <= track.clientWidth + 4) {
        scrollHint?.classList.add("hint-hidden");
      }
    });
  }
</script>
