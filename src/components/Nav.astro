<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 1.1rem 0;
    background: transparent;
    transition: background 0.3s var(--ease-out), padding 0.3s var(--ease-out), backdrop-filter 0.3s ease;
  }
  .nav.scrolled,
  .nav.menu-open {
    background: rgba(18, 24, 15, 0.92);
    backdrop-filter: blur(10px);
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(245, 239, 227, 0.08);
  }
  .announce-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: var(--amber-500);
    padding: 0.55rem 2.5rem 0.55rem 1rem;
    position: relative;
    text-align: center;
  }
  .nav.announce-hidden .announce-banner {
    display: none;
  }
  .announce-link {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.4rem 0.6rem;
    text-decoration: none;
    color: var(--forest-900);
    font-family: var(--font-label);
    font-size: 0.82rem;
  }
  .announce-text strong {
    font-weight: 800;
  }
  .announce-cta {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
    white-space: nowrap;
  }
  .announce-close {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--forest-900);
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.7;
    padding: 0.25rem;
  }
  .announce-close:hover {
    opacity: 1;
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    position: relative;
    z-index: 2;
  }
  .wordmark {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .wordmark img {
    height: 48px;
    width: auto;
    display: block;
  }
  .links {
    display: none;
    gap: 2rem;
    font-family: var(--font-label);
    font-size: 0.9rem;
    font-weight: 500;
  }
  .links a {
    color: rgba(245, 239, 227, 0.85);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .links a:hover {
    opacity: 0.7;
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .join-btn {
    padding: 0.6rem 1.3rem;
    font-size: 0.85rem;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
  }
  .hamburger span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--cream-100);
    transition: transform 0.25s var(--ease-out), opacity 0.2s ease;
  }
  .nav.menu-open .hamburger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav.menu-open .hamburger span:nth-child(2) {
    opacity: 0;
  }
  .nav.menu-open .hamburger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    top: 0;
    z-index: 1;
    background: var(--forest-900);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    transform: translateY(-100%);
    transition: transform 0.35s var(--ease-out);
  }
  .nav.menu-open .mobile-menu {
    transform: translateY(0);
  }
  .mobile-menu a {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--cream-100);
    text-decoration: none;
  }
  .mobile-join {
    font-family: var(--font-label);
    font-size: 1rem;
    margin-top: 1rem;
  }

  @media (min-width: 860px) {
    .links {
      display: flex;
    }
    .hamburger {
      display: none;
    }
    .mobile-menu {
      display: none;
    }
  }
</style>

<script>
  const nav = document.getElementById("site-nav");
  const hamburger = document.getElementById("hamburger-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const announceClose = document.getElementById("announce-close");

  const ANNOUNCE_KEY = "dudela-announce-dismissed-spit-up-society-aug4";
  try {
    if (localStorage.getItem(ANNOUNCE_KEY)) {
      nav?.classList.add("announce-hidden");
    }
  } catch {}

  announceClose?.addEventListener("click", () => {
    nav?.classList.add("announce-hidden");
    try {
      localStorage.setItem(ANNOUNCE_KEY, "1");
    } catch {}
  });

  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 60) nav.classList.add("scrolled");
    else nav.classList.remove("scrolled");
  };
  document.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  function closeMenu() {
    nav?.classList.remove("menu-open");
    hamburger?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }
  function toggleMenu() {
    const isOpen = nav?.classList.toggle("menu-open");
    hamburger?.setAttribute("aria-expanded", isOpen ? "true" : "false");
    document.body.style.overflow = isOpen ? "hidden" : "";
  }

  hamburger?.addEventListener("click", toggleMenu);
  mobileMenu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeMenu));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMenu();
  });
</script>
