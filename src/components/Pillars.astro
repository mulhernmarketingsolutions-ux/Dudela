---
import { pillars } from "../data/pillars.js";
---
<section class="pillars section-dark">
  <div class="container">
    <p class="eyebrow">The six pillars</p>
    <div class="pillars-grid">
      {pillars.map((p, i) => (
        <div class="pillar-card" tabindex="0" role="button" aria-label={`${p.name} — flip for more, or press Enter`}>
          <div class="pillar-card-inner">
            <div class="pillar-face pillar-front">
              {p.img && <img class="pillar-photo" src={p.img} alt={p.name} loading="lazy" />}
              <div class="pillar-scrim"></div>
              <span class="pillar-index">{String(i + 1).padStart(2, "0")}</span>
              <div class="pillar-copy">
                <h3>{p.name}</h3>
                <p>{p.line}</p>
                <span class="pillar-flip-hint">Tap for more &rarr;</span>
              </div>
            </div>
            <div class="pillar-face pillar-back">
              {p.img && <img class="pillar-photo pillar-photo-back" src={p.img} alt="" loading="lazy" />}
              <div class="pillar-back-scrim"></div>
              <div class="pillar-back-content">
                <span class="pillar-back-index">{String(i + 1).padStart(2, "0")}</span>
                <h3>{p.name}</h3>
                <p class="pillar-hook">{p.hook}</p>
              </div>
              <a href="/kit" class="pillar-cta">Explore the Prep Kit &rarr;</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pillars {
    padding: var(--space-6) 0;
  }
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
    margin-top: 2rem;
  }
  /* NOTE: this used to be a real 3D rotateY() flip. That relies on
     backface-visibility + transform-style: preserve-3d, which several mobile
     WebViews (and some in-app browsers) render incorrectly — both faces show
     at once, mirrored. Switched to a plain opacity/visibility cross-fade,
     which has zero 3D rendering dependency and works identically everywhere. */
  .pillar-card {
    position: relative;
    aspect-ratio: 3 / 4;
    cursor: pointer;
  }
  .pillar-card-inner {
    position: absolute;
    inset: 0;
  }
  .pillar-face {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: opacity 0.35s var(--ease-out), visibility 0.35s var(--ease-out);
  }
  .pillar-front {
    opacity: 1;
    visibility: visible;
    z-index: 2;
  }
  .pillar-back {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 1;
  }
  .pillar-card:hover .pillar-back,
  .pillar-card.flipped .pillar-back,
  .pillar-card:focus-visible .pillar-back {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    z-index: 2;
  }
  .pillar-card:hover .pillar-front,
  .pillar-card.flipped .pillar-front,
  .pillar-card:focus-visible .pillar-front {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 1;
  }
  .pillar-front {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(160deg, var(--forest-700) 0%, var(--forest-800) 100%);
  }
  .pillar-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .pillar-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(0deg, rgba(18, 24, 15, 0.92) 0%, rgba(18, 24, 15, 0.35) 55%, rgba(18, 24, 15, 0.15) 100%);
  }
  .pillar-index {
    position: relative;
    z-index: 2;
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--amber-500);
    margin-bottom: auto;
  }
  .pillar-copy {
    position: relative;
    z-index: 2;
    color: var(--cream-100);
  }
  .pillar-copy h3 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.15;
    margin: 0 0 0.4rem;
  }
  .pillar-copy p {
    font-size: 0.85rem;
    color: var(--text-on-dark-muted);
    margin: 0;
  }
  .pillar-flip-hint {
    display: block;
    margin-top: 0.9rem;
    font-family: var(--font-label);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--amber-500);
    opacity: 0.85;
  }

  .pillar-back {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.75rem;
    padding: 1.1rem;
    background: var(--forest-900);
    border: 1px solid var(--forest-600);
    color: var(--cream-100);
  }
  .pillar-photo-back {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    opacity: 0.55;
    filter: saturate(0.7) brightness(0.75);
  }
  .pillar-back-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(165deg, rgba(20, 27, 17, 0.55) 0%, rgba(15, 20, 13, 0.88) 60%, rgba(12, 16, 10, 0.96) 100%);
  }
  .pillar-back-content {
    position: relative;
    z-index: 2;
    overflow-y: auto;
    min-height: 0;
  }
  .pillar-back-index {
    display: block;
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--amber-500);
    margin-bottom: 0.5rem;
  }
  .pillar-back h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }
  .pillar-hook {
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--text-on-dark-muted);
    margin: 0;
  }
  .pillar-cta {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--forest-900);
    background: var(--amber-500);
    text-decoration: none;
    border-radius: var(--radius-sm);
    padding: 0.65rem 0.75rem;
  }
  .pillar-cta:hover {
    background: var(--amber-600);
  }
</style>

<script>
  // Flip cards: hover handles desktop, but touch devices have no hover, so a
  // tap toggles the flip. The flip-trigger listener lives ONLY on the front
  // face — never on the whole card — so it can never intercept a click meant
  // for the real <a class="pillar-cta"> link on the back.
  document.querySelectorAll(".pillar-card").forEach((card) => {
    const front = card.querySelector(".pillar-front");
    front?.addEventListener("click", (e) => {
      e.preventDefault();
      card.classList.toggle("flipped");
    });
    card.addEventListener("keydown", (e) => {
      const ke = e as KeyboardEvent;
      if ((ke.target as HTMLElement).closest(".pillar-cta")) return;
      if (ke.key === "Enter" || ke.key === " ") {
        ke.preventDefault();
        card.classList.toggle("flipped");
      }
    });
  });
</script>
