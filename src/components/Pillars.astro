---
import { pillars } from "../data/pillars.js";
---
<section class="pillars section-dark">
  <div class="container">
    <p class="eyebrow">The six pillars</p>
    <div class="pillars-grid">
      {pillars.map((p, i) => (
        <a class="pillar-card" href={`/kit#${p.slug}`}>
          {p.img && <img class="pillar-photo" src={p.img} alt={p.name} loading="lazy" />}
          <div class="pillar-scrim"></div>
          <span class="pillar-index">{String(i + 1).padStart(2, "0")}</span>
          <div class="pillar-copy">
            <h3>{p.name}</h3>
            <p>{p.line}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .pillars {
    padding: var(--space-6) 0;
  }
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .pillar-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-sm);
    overflow: hidden;
    text-decoration: none;
    color: var(--cream-100);
    padding: 1.25rem;
    background: linear-gradient(160deg, var(--forest-700) 0%, var(--forest-800) 100%);
    transition: transform 0.3s var(--ease-out);
  }
  .pillar-card:hover {
    transform: translateY(-4px);
  }
  .pillar-card:hover .pillar-photo {
    transform: scale(1.05);
  }
  .pillar-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    transition: transform 0.5s var(--ease-out);
  }
  .pillar-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(0deg, rgba(18, 24, 15, 0.92) 0%, rgba(18, 24, 15, 0.35) 55%, rgba(18, 24, 15, 0.15) 100%);
  }
  .pillar-index {
    position: relative;
    z-index: 2;
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--amber-500);
    margin-bottom: auto;
  }
  .pillar-copy {
    position: relative;
    z-index: 2;
  }
  .pillar-card h3 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.15;
    margin: 0 0 0.4rem;
  }
  .pillar-card p {
    font-size: 0.85rem;
    color: var(--text-on-dark-muted);
    margin: 0;
  }
</style>
