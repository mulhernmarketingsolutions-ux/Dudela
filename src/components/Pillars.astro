---
import { pillars } from "../data/pillars.js";
---
<section class="pillars section-dark">
  <div class="container">
    <p class="eyebrow">The six pillars</p>
    <div class="pillars-grid">
      {pillars.map((p, i) => (
        <div class="pillar-card" tabindex="0" role="button" aria-label={`${p.name} — flip for more, or press Enter`}>
          <div class="pillar-card-inner">
            <div class="pillar-face pillar-front">
              {p.img && <img class="pillar-photo" src={p.img} alt={p.name} loading="lazy" />}
              <div class="pillar-scrim"></div>
              <span class="pillar-index">{String(i + 1).padStart(2, "0")}</span>
              <div class="pillar-copy">
                <h3>{p.name}</h3>
                <p>{p.line}</p>
                <span class="pillar-flip-hint">Tap for more &rarr;</span>
              </div>
            </div>
            <div class="pillar-face pillar-back">
              <div>
                <span class="pillar-back-index">{String(i + 1).padStart(2, "0")}</span>
                <h3>{p.name}</h3>
                <p class="pillar-hook">{p.hook}</p>
              </div>
              <a href="/kit#buy" class="pillar-cta">See it in the Prep Kit &rarr;</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pillars {
    padding: var(--space-6) 0;
  }
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .pillar-card {
    position: relative;
    aspect-ratio: 3 / 4;
    perspective: 1200px;
    cursor: pointer;
  }
  .pillar-card-inner {
    position: absolute;
    inset: 0;
    transition: transform 0.6s var(--ease-out);
    transform-style: preserve-3d;
    -webkit-transform-style: preserve-3d;
  }
  .pillar-card:hover .pillar-card-inner,
  .pillar-card.flipped .pillar-card-inner,
  .pillar-card:focus-visible .pillar-card-inner {
    transform: rotateY(180deg);
    -webkit-transform: rotateY(180deg);
  }
  .pillar-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .pillar-front {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(160deg, var(--forest-700) 0%, var(--forest-800) 100%);
  }
  .pillar-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .pillar-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(0deg, rgba(18, 24, 15, 0.92) 0%, rgba(18, 24, 15, 0.35) 55%, rgba(18, 24, 15, 0.15) 100%);
  }
  .pillar-index {
    position: relative;
    z-index: 2;
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--amber-500);
    margin-bottom: auto;
  }
  .pillar-copy {
    position: relative;
    z-index: 2;
    color: var(--cream-100);
  }
  .pillar-copy h3 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.15;
    margin: 0 0 0.4rem;
  }
  .pillar-copy p {
    font-size: 0.85rem;
    color: var(--text-on-dark-muted);
    margin: 0;
  }
  .pillar-flip-hint {
    display: block;
    margin-top: 0.9rem;
    font-family: var(--font-label);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--amber-500);
    opacity: 0.85;
  }

  .pillar-back {
    transform: rotateY(180deg);
    -webkit-transform: rotateY(180deg);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.5rem;
    background: linear-gradient(160deg, var(--forest-800) 0%, var(--forest-900) 100%);
    border: 1px solid var(--forest-600);
    color: var(--cream-100);
  }
  .pillar-back-index {
    display: block;
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--amber-500);
    margin-bottom: 0.75rem;
  }
  .pillar-back h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    line-height: 1.2;
    margin: 0 0 0.75rem;
  }
  .pillar-hook {
    font-size: 0.88rem;
    line-height: 1.45;
    color: var(--text-on-dark-muted);
    margin: 0;
  }
  .pillar-cta {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.82rem;
    color: var(--amber-500);
    text-decoration: none;
    border-top: 1px solid var(--forest-600);
    padding-top: 1rem;
    transition: gap 0.2s ease;
  }
  .pillar-cta:hover {
    text-decoration: underline;
  }
</style>

<script>
  // Flip cards: hover handles desktop, but touch devices have no hover, so a
  // tap toggles the flip. Taps on the CTA itself are left alone so the link
  // still navigates normally.
  document.querySelectorAll(".pillar-card").forEach((card) => {
    function toggle(e: Event) {
      if ((e.target as HTMLElement).closest(".pillar-cta")) return;
      e.preventDefault();
      card.classList.toggle("flipped");
    }
    card.addEventListener("click", toggle);
    card.addEventListener("keydown", (e) => {
      const ke = e as KeyboardEvent;
      if (ke.key === "Enter" || ke.key === " ") {
        ke.preventDefault();
        card.classList.toggle("flipped");
      }
    });
  });
</script>
