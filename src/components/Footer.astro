<script>
  const form = document.getElementById("newsletter-form") as HTMLFormElement | null;
  const status = document.getElementById("newsletter-status") as HTMLParagraphElement | null;
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
    btn.disabled = true;
    if (status) status.textContent = "Signing up…";
    try {
      const res = await fetch("/api/lead-magnet", { method: "POST", body: new FormData(form) });
      const data = await res.json();
      if (data.ok) {
        if (status) status.textContent = "You're in. Welcome to the list.";
        form.reset();
      } else {
        if (status) status.textContent = data.error || "Something went wrong. Please try again.";
        btn.disabled = false;
      }
    } catch {
      if (status) status.textContent = "Something went wrong. Please try again.";
      btn.disabled = false;
    }
  });
</script>

