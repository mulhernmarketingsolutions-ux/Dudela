---
import PhotoPlaceholder from "./PhotoPlaceholder.astro";
import { episodes as allEpisodes } from "../data/episodes.js";

// Most recent 8 episodes for the homepage row. Full archive lives on /podcast.
const episodes = allEpisodes.slice(0, 8).map((e) => e.title);
---
<section class="podcast section-light">
  <div class="container">
    <div class="podcast-head">
      <div>
        <p class="eyebrow">The Dudela Podcast</p>
        <h2>John &amp; Mike, unfiltered.</h2>
      </div>
      <a href="/podcast" class="btn btn-ghost">All Episodes</a>
    </div>
    <div class="episode-row">
      {episodes.map((ep) => (
        <a href="/podcast" class="episode-card">
          <PhotoPlaceholder label={`Ep. thumbnail: ${ep}`} ratio="16/9" />
          <p>{ep}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .podcast {
    padding: var(--space-6) 0;
  }
  .podcast-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .podcast-head h2 {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 3.6vw, 2.4rem);
    margin: 0.4rem 0 0;
  }
  .podcast-head .btn-ghost {
    border-color: var(--text-on-light-muted);
    color: var(--text-on-light);
  }
  .episode-row {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
  }
  .episode-card {
    flex: 0 0 auto;
    width: 260px;
    text-decoration: none;
    color: var(--text-on-light);
  }
  .episode-card p {
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 0.95rem;
    margin: 0.75rem 0 0;
  }
</style>
